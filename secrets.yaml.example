# Copy this file to secrets.yaml and fill in your values.
# secrets.yaml is gitignored — never commit it.

wifi_ssid: "YourNetworkName"
wifi_password: "YourWiFiPassword"
ap_password: "espcure-setup"

# Generate with: python3 -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
api_encryption_key: "REPLACE_WITH_32_BYTE_BASE64_KEY"

# Any strong password
ota_password: "REPLACE_WITH_OTA_PASSWORD"
